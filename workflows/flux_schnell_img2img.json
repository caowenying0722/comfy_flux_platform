{
  "_meta": {
    "name": "flux-schnell-fp8-img2img",
    "note": "ComfyUI API prompt for FLUX.1-schnell FP8 checkpoint. Requires recent ComfyUI with Flux nodes and flux1-schnell-fp8.safetensors under models/checkpoints."
  },
  "1": {
    "class_type": "CheckpointLoaderSimple",
    "inputs": {
      "ckpt_name": "flux1-schnell-fp8.safetensors"
    }
  },
  "2": {
    "class_type": "LoadImage",
    "inputs": {
      "image": "{{input_image}}"
    }
  },
  "3": {
    "class_type": "VAEEncode",
    "inputs": {
      "pixels": ["2", 0],
      "vae": ["1", 2]
    }
  },
  "4": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "text": "{{prompt}}",
      "clip": ["1", 1]
    }
  },
  "5": {
    "class_type": "ModelSamplingFlux",
    "inputs": {
      "max_shift": 1.15,
      "base_shift": 0.5,
      "width": "{{width}}",
      "height": "{{height}}",
      "model": ["1", 0]
    }
  },
  "6": {
    "class_type": "FluxGuidance",
    "inputs": {
      "guidance": 3.5,
      "conditioning": ["4", 0]
    }
  },
  "7": {
    "class_type": "BasicGuider",
    "inputs": {
      "model": ["5", 0],
      "conditioning": ["6", 0]
    }
  },
  "8": {
    "class_type": "RandomNoise",
    "inputs": {
      "noise_seed": "{{seed}}"
    }
  },
  "9": {
    "class_type": "KSamplerSelect",
    "inputs": {
      "sampler_name": "euler"
    }
  },
  "10": {
    "class_type": "BasicScheduler",
    "inputs": {
      "scheduler": "simple",
      "steps": 4,
      "denoise": 0.65,
      "model": ["5", 0]
    }
  },
  "11": {
    "class_type": "SamplerCustomAdvanced",
    "inputs": {
      "noise": ["8", 0],
      "guider": ["7", 0],
      "sampler": ["9", 0],
      "sigmas": ["10", 0],
      "latent_image": ["3", 0]
    }
  },
  "12": {
    "class_type": "VAEDecode",
    "inputs": {
      "samples": ["11", 0],
      "vae": ["1", 2]
    }
  },
  "13": {
    "class_type": "SaveImage",
    "inputs": {
      "filename_prefix": "comfy_flux_platform/flux_schnell",
      "images": ["12", 0]
    }
  }
}
