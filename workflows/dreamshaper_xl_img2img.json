{
  "_meta": {
    "name": "dreamshaper-xl-lightning-img2img",
    "note": "DreamShaper XL Lightning img2img workflow for stronger stylized generation on legacy ComfyUI."
  },
  "1": {
    "class_type": "CheckpointLoaderSimple",
    "inputs": {
      "ckpt_name": "DreamShaperXL_Lightning.safetensors"
    }
  },
  "2": {
    "class_type": "LoadImage",
    "inputs": {
      "image": "{{input_image}}"
    }
  },
  "3": {
    "class_type": "VAEEncode",
    "inputs": {
      "pixels": ["9", 0],
      "vae": ["1", 2]
    }
  },
  "4": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "text": "{{prompt}}",
      "clip": ["1", 1]
    }
  },
  "5": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "text": "{{negative_prompt}}",
      "clip": ["1", 1]
    }
  },
  "6": {
    "class_type": "KSampler",
    "inputs": {
      "seed": "{{seed}}",
      "steps": 8,
      "cfg": 2.0,
      "sampler_name": "dpmpp_sde",
      "scheduler": "karras",
      "denoise": 0.62,
      "model": ["1", 0],
      "positive": ["4", 0],
      "negative": ["5", 0],
      "latent_image": ["3", 0]
    }
  },
  "7": {
    "class_type": "VAEDecode",
    "inputs": {
      "samples": ["6", 0],
      "vae": ["1", 2]
    }
  },
  "8": {
    "class_type": "SaveImage",
    "inputs": {
      "filename_prefix": "comfy_flux_platform/dreamshaper_xl",
      "images": ["7", 0]
    }
  },
  "9": {
    "class_type": "ImageScale",
    "inputs": {
      "image": ["2", 0],
      "upscale_method": "lanczos",
      "width": "{{width}}",
      "height": "{{height}}",
      "crop": "center"
    }
  }
}
